        CHEERIO[cheerio - HTML 解析]
        JSDOMP[jsdom]
        MERCP[Mecury Parser - 全文提取]
        RSSP[rss-parser - RSS 解析]
    end

    subgraph "Proxy Layer"
        HTTP_PROXY[HTTP Proxy]
        SOCKS_PROXY[SOCKS5 Proxy]
        PAC_PROXY[PAC Proxy]
        MULTI_PROXY[Multi-Proxy Failover]
    end

    OFETCH --> HTTP_PROXY
    OFETCH --> SOCKS_PROXY
    OFETCH --> PAC_PROXY
    OFETCH --> MULTI_PROXY

    OFETCH --> CHEERIO
    OFETCH --> MERCP

    PW --> CHROM
    PW --> CHEERIO

    RSSP --> OFETCH

    GOTCOMPAT --> OFETCH
