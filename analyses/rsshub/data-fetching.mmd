flowchart TD
    subgraph "HTTP Clients"
        OFETCH[ofetch - 统一 HTTP 客户端]
        GOTCOMPAT[got 兼容适配层]
    end

    subgraph "Browser Automation"
        PW[Playwright]
        CHROM[Chromium / Chrome]
    end

