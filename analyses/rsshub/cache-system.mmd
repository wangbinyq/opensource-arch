flowchart LR
    subgraph "Cache Abstraction"
        IC[interface CacheModule]
    end

    subgraph "Cache Backends"
        MEM[Memory LRU Cache]
        REDIS[Redis]
        HTTP[HTTP Cache - Remote]
        KV[Cloudflare KV]
    end

    subgraph "Cache Keys"
        RC[Route Cache - xxhash64]
        CC[Content Cache - per item]
        LC[Lock Cache - request control]
    end

    subgraph "Usage"
        MW[Cache Middleware]
        TG[tryGet utility]
        GC[globalCache]
    end

    MW --> RC
    TG --> CC
    MW --> LC

    RC --> IC
    CC --> IC
    LC --> IC

    IC --> MEM
    IC --> REDIS
    IC --> HTTP
    IC --> KV
